{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch VTT Server",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "main:app",
                "--reload",
                "--host", "0.0.0.0",
                "--port", "8000"
            ],
            "cwd": "${workspaceFolder}/server",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/server"
            }
        }
    ]
}